def fibonacci(n):
    """
    Generates a list of the first n Fibonacci numbers.
    The sequence starts with 0 and 1.
    """
    if n <= 0:
        return []
    if n == 1:
        return [0]
    
    fib_list = [0, 1]
    while len(fib_list) < n:
        next_fib = fib_list[-1] + fib_list[-2]
        fib_list.append(next_fib)
    return fib_list


