

# Complete the solve function below.
def solve(s):
    sa=""
    #Method_2
    sa+=s[0].upper()
    for i in range(1,len(s)):
        if s[i]==" ":
            sa+=s[i]
        elif s[i-1]==" ":
            if s[i]==" ":
                sa+=s[i]
            else:
                sa+=s[i].upper()
        else:
            sa+=s[i]
    return sa

