def print_formatted(number):
    # Calculate the width based on the binary representation of the maximum number
    width = len(bin(number)[2:])
    
    for i in range(1, number + 1):
        # Convert to respective formats and slice off prefixes (0o, 0x, 0b)
        decimal = str(i)
        octal = oct(i)[2:]
        hexa = hex(i)[2:].upper()
        binary = bin(i)[2:]
        
        # Print with padding right-justified
        print(f"{decimal.rjust(width)} {octal.rjust(width)} {hexa.rjust(width)} {binary.rjust(width)}")
