# Enter your code here. Read input from STDIN. Print output to STDOUT
import numpy as np

# Read N and M
n, m = map(int, input().split())

# Read array A and B, converting input to numpy arrays of integers
A = np.array([input().split() for _ in range(n)], dtype=int)
B = np.array([input().split() for _ in range(n)], dtype=int)

# Print results of element-wise operations
print(A + B)
print(A - B)
print(A * B)
print(A // B)  # Integer division
print(A % B)   # Modulo
print(A ** B)  # Power
