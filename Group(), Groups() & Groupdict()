# Enter your code here. Read input from STDIN. Print output to STDOUT
import re

S = input()
# Search for an alphanumeric character ([a-zA-Z0-9]) that is followed by
# one or more occurrences of the same character (\\1+)
m = re.search(r'([a-zA-Z0-9])\1+', S)

if m:
    # If a match is found, print the character from the first capturing group
    print(m.group(1))
else:
    # Otherwise, print -1
    print(-1)
